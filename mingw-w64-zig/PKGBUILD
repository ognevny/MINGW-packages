# Maintainer:  Matheus Catarino <matheus-catarino@hotmail.com>

# when set to 1, the bootstrap tarball is downloaded. it contains a build script and all required
# vendored deps, which are compiled staticly. when set to 0, the github tarball is used and zig
# is compiled using itself.
_bootstrap=1

_realname=zig
pkgbase=mingw-w64-zig
pkgname="${MINGW_PACKAGE_PREFIX}-zig"
pkgver=0.13.0
pkgrel=1
pkgdesc='General-purpose programming language and toolchain for maintaining robust, optimal, and reusable software (mingw-w64)'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://ziglang.org'
msys2_repository_url='https://github.com/ziglang/zig'
license=('spdx:MIT')
msys2_references=(
  'archlinux: zig'
)
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja")
if (( _bootstrap )); then
makedepends=("${MINGW_PACKAGE_PREFIX}-clang"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-zlib")
source=("https://github.com/ziglang/zig/releases/download/${pkgver}/zig-bootstrap-${pkgver}.tar.xz"
        "use-clang.patch")
sha256sums=('cd446c084b5da7bc42e8ad9b4e1c910a957f2bf3f82bcc02888102cd0827c139'
            '0290b34e9bac11dc10274e8d427917021cc7b79e65dd3b82f849a439274d8c8f')
_pkgfn=zig-bootstrap-${pkgver}
else
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-llvm"
             "${MINGW_PACKAGE_PREFIX}-lld"
             "${MINGW_PACKAGE_PREFIX}-clang"
             "${MINGW_PACKAGE_PREFIX}-zstd")
depends=("${MINGW_PACKAGE_PREFIX}-llvm-libs"
         "${MINGW_PACKAGE_PREFIX}-clang-libs"
         "${MINGW_PACKAGE_PREFIX}-libwinpthread")
source=("https://github.com/ziglang/zig/archive/${pkgver}/${_realname}-${pkgver}.tar.gz"
        "skip-localhost-test.patch")
sha256sums=('d3912858003e340f315224bf177d0f441d86b81f62854f5c141b6d51ab6b5516'
            '2d25a8fddb04272a20acf5680ec847c49ee9f41868601df6b020b9d3053b01d0')
_pkgfn=${_realname}-${pkgver}
fi

prepare() {
  cd $_pkgfn

  if (( _bootstrap )); then
    patch -p1 -i "${srcdir}/use-clang.patch"
  else
    patch -p1 -i "${srcdir}/skip-localhost-test.patch"
  fi
}

build() {
  cd $_pkgfn
  if (( _bootstrap )); then
    # stage 3 requires libz.a
    mkdir -p out/host/lib && cp -a "${MINGW_PREFIX}/lib/libz.a" out/host/lib
    ./build x86_64-windows-gnu baseline
  else
    MSYS2_ARG_CONV_EXCL="--prefix="
      zig build \
        --prefix="${MINGW_PREFIX}" \
        -Dflat \
        -Denable-llvm \
        -Doptimize=ReleaseFast \
        -Dstrip \
        -Dtarget=x86_64-windows-gnu \
        -Dcpu=baseline \
        -Dversion-string="0.13.0 (Rev${pkgrel}, built by MSYS2 project)"
  fi
}

